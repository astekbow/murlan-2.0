{
  "extends": ["development"],
  "hints": {
    "no-inline-styles": "off",
    "axe/aria": ["default", {
      "aria-valid-attr-value": "off"
    }],
    "axe/forms": ["default", {
      "autocomplete-valid": "off"
    }],
    "compat-api/css": ["default", {
      "ignore": ["text-size-adjust"]
    }]
  }
}
