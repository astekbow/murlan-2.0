# ── Murlan server configuration ──────────────────────────────────────────────
# Copy to .env and fill in. In production the JWT + webhook secrets are REQUIRED
# (the server refuses to boot with NODE_ENV=production without them).

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5173

# ── Auth (REQUIRED in production) ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TTL=15m
REFRESH_TTL=7d

# ── Payments ─────────────────────────────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=change-me-webhook   # REQUIRED in production
PAYMENT_WEBHOOK_IPS=                        # optional CSV of allowed webhook source IPs (empty = any). Needs the proxy to set X-Forwarded-For authoritatively.
RAKE_BPS=1000                              # house rake, basis points (1000 = 10%)
# Staging/demo ONLY: allow the stub payment + console-email providers under
# NODE_ENV=production so the app can be deployed before Stripe/PayPal + SMTP are
# wired (mock deposits; verification/reset emails are printed to the server log).
# NEVER set true for a real-money instance — leave false to keep the fail-closed guard.
ALLOW_STUB_PROVIDERS=false

# ── Crypto deposits: on-chain USDT-TRC20 via TxID (fee-free) ─────────────────
# Deposits are made by sending USDT-TRC20 to YOUR receiving address (set
# TRON_DEPOSIT_ADDRESS below); the player pastes the TxID and the server verifies
# it on-chain via TronGrid. No hosted-checkout provider is used. See the payout
# section below for TRON_DEPOSIT_ADDRESS / TRONGRID_API_KEY.

# ── Email via Resend (password reset + verification) ─────────────────────────
# Get the key at resend.com → API Keys. To email ANY player, verify your sending
# DOMAIN in Resend (add the DNS records) and set EMAIL_FROM to an address on it.
# Leave EMAIL_FROM blank to use Resend's test sender (onboarding@resend.dev) —
# that only delivers to your OWN Resend account email (fine for testing).
RESEND_API_KEY=
EMAIL_FROM=                 # e.g. Murlan <noreply@yourdomain.com>

# ── Admin ────────────────────────────────────────────────────────────────────
# This account is auto-promoted to admin on every boot (so you can open the admin
# panel: users, balances, withdrawals). Register it first, then it becomes admin.
ADMIN_EMAIL=

# ── Ops alerts (Telegram) ────────────────────────────────────────────────────
# Get a bot token from @BotFather, then message the bot once and read your chat id
# from https://api.telegram.org/bot<TOKEN>/getUpdates (the "chat":{"id":...}).
# When BOTH are set, the owner gets an instant Telegram ping on every withdrawal
# request (player, amount, address, KYC). Leave empty to disable. The SAME bot + chat
# are reused by the optional Prometheus/Alertmanager monitoring stack (money-integrity
# alerts) — see deploy/OBSERVABILITY.md and the `monitoring` compose profile.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set this to ALSO turn ON the inbound admin bot ("run the casino from your phone"):
# new-withdrawal alerts gain [✅ Approve] [❌ Reject] buttons, and /stats /withdrawals
# /treasury /help work in the chat. Telegram POSTs updates to /api/telegram/webhook
# and echoes this secret in the X-Telegram-Bot-Api-Secret-Token header (verified
# fail-closed). Pick a long random string. Requires CLIENT_ORIGIN to be your real
# https:// domain (the webhook is auto-registered on boot). Leave empty = alerts only,
# no buttons/commands. Only TELEGRAM_CHAT_ID may issue commands. See TELEGRAM_ADMIN_BOT_PLAN.md.
TELEGRAM_WEBHOOK_SECRET=

# Data retention: prune match move-logs (game_actions) older than N days during the
# periodic sweep. 0 = keep forever (the safe default — replays/audit stay available).
MOVELOG_RETENTION_DAYS=0

# Semi-auto withdrawal triage: withdrawals at/below this many CENTS from a
# KYC-verified player are flagged "✅ safe to fast-track" in the Telegram alert;
# everything else is flagged "⚠️ review". 0 = off (all flagged for review).
# Example: 5000 = $50.
AUTO_WITHDRAW_MAX_CENTS=0
# Per-user 24h AUTO-payout cap (cents). Once a player's withdrawals in the last 24h
# exceed this, further ones go to MANUAL review instead of auto — caps how fast a
# single (or compromised) account can drain the Binance hot wallet, and curbs AML
# structuring. 0 = no cap. STRONGLY recommended on a live system, e.g. 20000 = $200.
DAILY_AUTO_WITHDRAW_CAP_CENTS=0
# GLOBAL 24h auto-payout budget across ALL users (cents). Once total auto-paid in the
# last 24h would breach this, further auto-sends are forced to MANUAL — a hot-wallet-drain
# limiter independent of any single account. 0 = off. Example: 200000 = $2,000/day.
GLOBAL_AUTO_WITHDRAW_CAP_CENTS=0
# PER-DESTINATION-ADDRESS 24h auto-payout cap (cents). Once a single address has received
# this much auto-pay in 24h, further ones go MANUAL (stops a collusion cash-out funnel).
# 0 = off. Example: 50000 = $500/address/day.
DEST_AUTO_WITHDRAW_CAP_CENTS=0

# "Time to sweep" alert: when the on-chain USDT across your deposit addresses reaches this
# many CENTS, the Telegram bot pings you to consolidate it into Binance (with the LOCAL
# tools/sweep-app — never server-side). 0 = off. Example: 10000 = $100. The /deposits bot
# command shows the live total + funded addresses on demand regardless of this setting.
SWEEP_ALERT_CENTS=0

# ── AUTOMATIC crypto payout (Binance withdraw API) ───────────────────────────
# ⚠️ Sends REAL money automatically for withdrawals ≤ AUTO_WITHDRAW_MAX_CENTS from
# KYC-verified players. Larger/unverified stay manual (you get the Telegram alert).
# Turns ON only when BINANCE_API_KEY + BINANCE_API_SECRET are set AND the cap > 0.
AUTO_WITHDRAW_CURRENCY=usdttrc20     # payout coin/network (players must withdraw to this network)
#
# Sends from your Binance Spot balance (flat network fee, no %). API key needs
# "Enable Withdrawals" + your server IP WHITELISTED, and the account's withdrawal
# ADDRESS whitelist OFF (to pay arbitrary player addresses). ⚠️ Binance has NO
# testnet for real withdrawals — test live with a tiny amount ($1-2) to YOUR OWN
# address before enabling for players. SECURITY: these creds can move money — a
# host breach could drain the payout balance; the small cap is the blast-radius limiter.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Fee-free USDT-TRC20 deposits (on-chain TxID verify, free via TronGrid) ───
# PREFERRED — TRON_DEPOSIT_XPUB: a watch-only account xpub. Each player gets a
# UNIQUE deposit address derived from it, so a deposit is attributed by which
# address received it (theft-proof — no claim-jacking) and the server holds NO
# private keys. Generate it OFFLINE with tools/tron-xpub.mjs: keep the 24-word
# mnemonic in cold storage, put ONLY the xpub here.
TRON_DEPOSIT_XPUB=                   # account-level TRON xpub (xpub6...) — watch-only
# LEGACY fallback — a single shared address. Claim-jackable (anyone who sees a TxID
# on the explorer can claim it). Used ONLY if TRON_DEPOSIT_XPUB is empty. Prefer the xpub.
TRON_DEPOSIT_ADDRESS=                # single USDT-TRC20 receiving address (T...)
TRONGRID_API_KEY=                    # free TronGrid API key (higher rate limits)

# ── Real-time / scaling ──────────────────────────────────────────────────────
REDIS_URL=                                 # set to enable the Socket.IO Redis adapter
TURN_MS=30000                              # per-turn timer
COUNTDOWN_MS=3000                          # ready-check countdown
ABANDON_MS=30000                           # reconnect grace before a disconnect forfeits

# ── Database (Prisma/PostgreSQL; in-memory if left blank) ────────────────────
# Supabase project "murlan" (ref knvkzgtwisahiddaqnsc, region eu-central-1).
# Replace [PASSWORD] with the project's DB password
# (Supabase dashboard → Project Settings → Database → copy/reset password).
# NOTE: this project's pooler host is "aws-1-..." (not aws-0). Confirm yours via
# Dashboard → Connect, or the Management API config/database/pooler endpoint.
#   App (pooled, transaction mode — port 6543):
#   DATABASE_URL=postgresql://postgres.knvkzgtwisahiddaqnsc:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   Migrations (pooled, session mode — port 5432 on the pooler, IPv4-safe):
#   DIRECT_URL=postgresql://postgres.knvkzgtwisahiddaqnsc:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# Supabase client keys (NOT used by this Prisma server; reference only):
# SUPABASE_URL=https://knvkzgtwisahiddaqnsc.supabase.co
# SUPABASE_ANON_KEY=...          # client-side, RLS-restricted
# SUPABASE_SERVICE_ROLE_KEY=...  # server-side; only if you adopt supabase-js

# ── Compliance switches (spec §13) — OFF by default, enable per jurisdiction ──
KYC_REQUIRED=false
MIN_AGE=0                                  # e.g. 18 to enable age gating
GEO_BLOCKED_COUNTRIES=                     # CSV ISO-2, e.g. US,FR
RESPONSIBLE_GAMING=false                   # honor self-exclusion

# ── Money governance / AML rails (additive guards — defaults preserve current behavior) ──
# Four-eyes on a MANUAL balance adjustment (admin /adjust + Telegram /credit /debit): require
# a 2nd distinct admin. OFF by default (the owner is a solo admin; mandatory dual-control
# would lock them out). The per-call ceiling ($5,000), per-admin rolling-24h cap ($20,000),
# and the no-self-credit rule ALWAYS apply regardless of this flag.
ADJUST_DUAL_CONTROL=false
# Per-user rolling-24h cap on P2P transfers OUT (cents). 0 = UNLIMITED (transfers stay open,
# today's owner setting); >0 turns on the ledger-enforced AML rail. Example: 50000 = $500/day.
# (When RESPONSIBLE_GAMING/KYC/geo are ON, the transfer route ALSO runs the full compliance
# gate — incl. self-exclusion — on BOTH parties; with all those OFF this stays unlimited.)
DAILY_TRANSFER_CAP_CENTS=0
