// Murlan persistence schema (spec §11). The server uses in-memory repositories
// by default; when DATABASE_URL is set it uses the Prisma-backed adapters that
// implement the same repository interfaces, with $transaction for atomic money.
generator client {
  provider      = "prisma-client-js"
  // Bundle the Alpine/musl engine (the Docker base) alongside the dev one, so the
  // container never has to download an engine at runtime (it runs as non-root).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (Supabase pooler, port 6543) for the app
  directUrl = env("DIRECT_URL") // direct (port 5432) for `prisma migrate`
}

enum UserRole {
  user
  admin
}

enum AccountState {
  active
  frozen
  suspended
  banned
}

enum KycStatus {
  none
  pending
  verified
}

enum TransactionType {
  deposit
  withdrawal
  bet
  payout
  rake
  purchase
  transfer_out
  transfer_in
  admin_adjust
}

enum TransactionStatus {
  pending
  completed
  failed
}

enum MatchStatus {
  active
  settled
  cancelled
}

enum WithdrawalStatus {
  pending
  completed
  rejected
}

enum SeasonStatus {
  active
  archived
}

enum SupportStatus {
  open
  resolved
  closed
}

model User {
  id            String   @id @default(cuid())
  username      String // display value (original case)
  usernameLower String   @unique // case-insensitive uniqueness/lookup key
  email         String   @unique // stored lowercased
  passwordHash  String
  role          UserRole @default(user)
  // Granular admin scopes (RBAC). EMPTY = full admin (backward-compatible: every
  // existing admin keeps all powers). A non-empty list restricts that admin to
  // exactly those scopes. Ignored for non-admins (they fail the admin gate first).
  permissions   String[] @default([])
  balanceCents  Int      @default(0)
  createdAt     DateTime @default(now())

  // Bumped to force-invalidate ALL of a user's refresh tokens at once (e.g. on
  // ban or "log out of all devices"). Checked on every refresh.
  tokenVersion  Int     @default(0)
  emailVerified Boolean @default(false)

  // Account lifecycle (trust & safety): admin-set suspend/freeze/ban. Defaults to
  // active so every existing row is unaffected. `accountStateUntil` is a
  // suspension expiry (NULL = permanent / not applicable).
  accountState       AccountState @default(active)
  accountStateReason String?
  accountStateUntil  DateTime?

  // Per-player USDT-TRC20 deposit address (watch-only, derived from TRON_DEPOSIT_XPUB
  // at index `depositAddressIndex`). Unique → an on-chain deposit is attributed to
  // exactly one account by which address received it (theft-proof, no claim-jacking).
  depositAddress      String? @unique
  depositAddressIndex Int?    @unique

  // Compliance (§13)
  kycStatus         KycStatus @default(none)
  dateOfBirth       String?
  country           String?
  selfExcludedUntil DateTime?

  // Responsible-gaming self-imposed limits (cents per UTC day; null = no limit).
  dailyDepositLimitCents Int?
  dailyLossLimitCents    Int?

  // Progression & cosmetics (§2.3) — XP/stats only, never cashable. Level is
  // DERIVED from xp (see profile/level helper), not stored.
  xp              Int     @default(0)
  // Lifetime XP SPENT in the XP shop (§2.6 XP economy). `xp` is lifetime-earned and
  // NEVER decreases (level = levelInfo(xp) stays monotonic); the SPENDABLE balance is
  // (xp - xpSpent), clamped ≥ 0. Buying an XP cosmetic increments this, not xp.
  xpSpent         Int     @default(0)
  gamesPlayed     Int     @default(0)
  wins            Int     @default(0)
  biggestPotCents Int     @default(0)
  currentStreak   Int     @default(0)
  avatar          String? // cosmetic avatar id from a preset set

  // Engagement rewards (§2.6) — XP/cosmetic ONLY, never cashable. Gated by the
  // rewardsEnabled config (per-jurisdiction off switch).
  lastDailyClaim    DateTime?
  dailyStreak       Int       @default(0)
  cosmetics         String[]  @default([]) // owned cosmetic ids
  cardBack          String? // equipped card-back id
  tableFelt         String? // equipped felt-theme id
  claimedChallenges String[]  @default([]) // claimed challenge ids

  transactions         Transaction[]
  withdrawals          Withdrawal[]  @relation("WithdrawalUser")
  resolvedWithdrawals  Withdrawal[]  @relation("WithdrawalResolver") // withdrawals this admin approved/rejected
  matchSeats           MatchPlayer[]
  friendRequests       Friendship[]        @relation("FriendRequests")
  friendOf             Friendship[]        @relation("FriendOf")
  refreshTokens        RefreshToken[]
  adminActions         AdminAction[]       @relation("AdminActor")
  adminTargetedActions AdminAction[]       @relation("AdminTarget")
  verificationTokens   VerificationToken[]
  userSeasons          UserSeason[]
  supportTickets       SupportTicket[]
  foundedClubs         Club[]              @relation("ClubFounder")
  clubMembership       ClubMember?
  chatMessages         ChatMessage[]
  pushSubscriptions    PushSubscription[]

  // Hot-path indexes: XP leaderboard (topByXp, ORDER BY xp) + admin user listing (newest-first).
  @@index([xp])
  @@index([createdAt])
  @@map("users")
}

enum VerificationTokenType {
  email_verify
  password_reset
}

// Single-use, hashed, expiring tokens for email verification + password reset.
// Only the SHA-256 hash is stored (the raw token lives only in the emailed link),
// so a DB leak can't be used to verify/reset. Consumed on use (usedAt set).
model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  type      VerificationTokenType
  tokenHash String                @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("verification_tokens")
}

enum FriendStatus {
  pending
  accepted
  blocked
}

// Server-side record of issued refresh tokens (rotation + reuse detection +
// real revocation). A refresh JWT carries a `jti`; /refresh verifies the jti is
// present and unrevoked, rotates (revokes old, issues new), and on a reused jti
// revokes the whole `family`. Logout revokes the current jti.
model RefreshToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  userId    String
  family    String // rotation family id (shared across a rotation chain)
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// Audit trail for privileged admin actions (balance adjust, KYC change,
// withdrawal approve/reject). Immutable, append-only — the core fraud/AML control.
model AdminAction {
  id           String   @id @default(cuid())
  adminId      String
  action       String // 'balance_adjust' | 'kyc_set' | 'withdrawal_approve' | 'withdrawal_reject'
  targetUserId String?
  amountCents  Int?
  detail       String?
  createdAt    DateTime @default(now())

  admin      User  @relation("AdminActor", fields: [adminId], references: [id])
  // FK on the audited subject. Restrict (not Cascade/SetNull) so a user with
  // audit history can't be silently deleted and the immutable AML trail keeps
  // its referential link — orphaned audit rows are unacceptable for compliance.
  targetUser User? @relation("AdminTarget", fields: [targetUserId], references: [id], onDelete: Restrict)

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_actions")
}

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(pending)
  createdAt   DateTime     @default(now())

  requester User @relation("FriendRequests", fields: [requesterId], references: [id])
  addressee User @relation("FriendOf", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("friendships")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  amountCents Int // signed
  currency    String            @default("USD")
  status      TransactionStatus @default(completed)
  providerRef String?           @unique
  matchId     String?
  reason      String?
  createdAt   DateTime          @default(now())

  user  User   @relation(fields: [userId], references: [id])
  match Match? @relation(fields: [matchId], references: [id])

  @@index([userId])
  @@index([matchId])
  @@index([createdAt]) // date-range admin/reporting queries
  @@index([userId, createdAt]) // per-user paginated history (hot path)
  @@index([type, createdAt]) // revenue/reporting by type over time
  @@map("transactions")
}

model Match {
  id         String      @id
  type       String // '1v1' | '1v1v1' | '2v2'
  stakeCents Int
  rakeBps    Int
  potCents   Int
  status     MatchStatus @default(active)
  targetT    Int         @default(21)
  winnerSide Int?
  createdAt  DateTime    @default(now())
  endedAt    DateTime?

  players      MatchPlayer[]
  games        Game[]
  transactions Transaction[]

  // Crash-recovery sweep + admin views filter on status; index it to avoid a
  // full table scan as the table grows.
  @@index([status])
  @@map("matches")
}

model MatchPlayer {
  matchId    String
  userId     String
  seat       Int
  team       Int?
  finalScore Int    @default(0)

  match Match @relation(fields: [matchId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@id([matchId, seat])
  @@unique([matchId, userId]) // a user can occupy at most ONE seat in a match
  @@index([userId])
  @@map("match_players")
}

model Game {
  id             String   @id @default(cuid())
  matchId        String
  index          Int
  finishingOrder Int[]
  serverSeed     String? // null until revealed
  serverSeedHash String
  clientSeed     String
  nonce          Int
  revealed       Boolean  @default(false)
  createdAt      DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])

  @@unique([matchId, index])
  @@map("games")
}

// Match move-log: every applied move in turn order, for deterministic replay +
// dispute/audit. Standalone (no FK) — a matchId exists for every match (staked or
// casual), but a `matches` row is only created when stakes are escrowed, so a FK
// would reject casual-match actions. Keyed by (matchId, seq) for ordering.
model GameAction {
  matchId   String
  seq       Int // monotonic within the match (turn order)
  gameIndex Int
  seat      Int
  type      String // 'play' | 'pass' | 'switch' | 'forfeit' (free-text; no enum/migration)
  cards     Json? // played cards / given card; null for a pass / forfeit
  createdAt DateTime @default(now())

  @@id([matchId, seq])
  @@index([matchId])
  @@map("game_actions")
}

// In-app support / dispute tickets. A player can reference a match (dispute) or
// transaction; an admin resolves with a note (the action is also written to the
// immutable AdminAction audit trail). Standalone — links are soft (string ids).
model SupportTicket {
  id         String        @id @default(cuid())
  userId     String
  category   String // 'match' | 'payment' | 'account' | 'other'
  subject    String
  message    String
  status     SupportStatus @default(open)
  matchId    String? // optional dispute link
  adminNote  String?
  createdAt  DateTime      @default(now())
  resolvedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

// Anti-collusion / anti-bot telemetry: heuristic flags for MANUAL admin review
// (never auto-action). Standalone (soft userId/matchId links) — an analytics
// table, not part of the money/identity referential graph.
model SuspicionFlag {
  id        String   @id @default(cuid())
  userId    String
  type      String // 'bot_timing' | 'win_rate'
  severity  Int // 1 low · 2 medium · 3 high
  detail    String
  matchId   String?
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([reviewed])
  @@index([userId])
  @@index([createdAt])
  @@map("suspicion_flags")
}

// Browser Web Push subscriptions for re-engagement nudges (turn / match / reward).
// Standalone — userId is a soft string id (no FK). `endpoint` is unique so a
// device re-subscribing replaces its row. Real delivery needs VAPID keys.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// Club chat (§9 social) + moderation. All standalone (soft string ids, no FK).
// `username` is denormalized so history renders without a join.
model ChatMessage {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  username  String
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([userId])
  @@map("chat_messages")
}

model ChatReport {
  id         String   @id @default(cuid())
  messageId  String
  clubId     String
  reporterId String
  reason     String
  reviewed   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([reviewed])
  @@index([createdAt])
  @@map("chat_reports")
}

// Global per-user chat mute (silences a user in all club channels until `until`).
model UserMute {
  userId String   @id
  until  DateTime
  by     String // admin or founder userId who set it
  reason String

  @@map("user_mutes")
}

// Clubs (social): a player belongs to at most ONE club (ClubMember.userId is the
// PK), with a founder/member role. Foundation for club chat / leaderboards / tables.
model Club {
  id        String   @id @default(cuid())
  name      String
  tag       String   @unique // short uppercase tag shown by names, e.g. MUR
  founderId String
  createdAt DateTime @default(now())
  private   Boolean  @default(false) // hidden from the public list; join by code only
  joinCode  String?  @unique // share code for a private club (unique → no collisions; NULLs allowed)

  members     ClubMember[]
  tournaments Tournament[] // club-scoped tournaments; ON DELETE SET NULL degrades them to global
  // FK so a club always points at a real founder. Restrict: a user who founded a
  // club can't be hard-deleted out from under it (account-state ban is used instead).
  founder User         @relation("ClubFounder", fields: [founderId], references: [id], onDelete: Restrict)

  @@index([founderId])
  @@map("clubs")
}

model ClubMember {
  userId   String   @id // one club per user
  clubId   String
  role     String // 'founder' | 'member'
  joinedAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("club_members")
}

model Withdrawal {
  id                String           @id @default(cuid())
  userId            String
  amountCents       Int
  destination       String
  status            WithdrawalStatus @default(pending)
  createdAt         DateTime         @default(now())
  resolvedAt        DateTime?
  // Audit/dispute trail (all nullable, populated as a withdrawal progresses):
  providerRef       String? // payout provider's withdrawal/batch id (e.g. Binance)
  network           String? // payout network actually used (e.g. TRX)
  txHash            String? // on-chain transaction hash once known
  resolvedByAdminId String? // admin who approved/rejected (null = auto/system)
  failureReason     String? // short reason when a payout fails/reverses

  user            User  @relation("WithdrawalUser", fields: [userId], references: [id])
  // The admin who resolved this withdrawal — referential integrity on the audit trail.
  // SetNull: deleting/anonymizing an admin keeps the withdrawal row but drops the link.
  resolvedByAdmin User? @relation("WithdrawalResolver", fields: [resolvedByAdminId], references: [id], onDelete: SetNull)

  @@index([userId])
  // Admin withdrawal triage lists pending rows; index status to avoid a scan.
  @@index([status])
  @@index([createdAt])
  @@index([resolvedByAdminId]) // admin withdrawal-audit lookups by resolving admin
  @@map("withdrawals")
}

model DepositIntent {
  providerRef String   @id
  userId      String
  amountCents Int
  currency    String   @default("USD")
  createdAt   DateTime @default(now())

  @@index([createdAt]) // sweep stale/abandoned intents
  @@map("deposit_intents")
}

// Ranked competitive ladder (§ next-level). A Season is a rating window with its
// own MMR; UserSeason is a player's per-season rating row. Ratings are
// competitive/cosmetic ONLY — never cashable, never linked to the ledger.
model Season {
  id          String       @id @default(cuid())
  number      Int          @unique // 1-based, monotonically increasing
  name        String
  status      SeasonStatus @default(active)
  decayFactor Float        @default(0.5) // soft-reset pull applied when the NEXT season opens
  startedAt   DateTime     @default(now())
  endedAt     DateTime?

  userSeasons UserSeason[]

  // At most one active season; this index keeps the active-season lookup cheap.
  @@index([status])
  @@map("seasons")
}

model UserSeason {
  userId     String
  seasonId   String
  rating     Int      @default(1000)
  peakRating Int      @default(1000)
  games      Int      @default(0)
  wins       Int      @default(0)
  updatedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])

  @@id([seasonId, userId])
  // Leaderboard query: top-by-rating within a season.
  @@index([seasonId, rating])
  @@index([userId])
  @@map("user_seasons")
}

// Single-elimination, real-money tournament. playerIds + bracket are stored as JSON
// so escrowed buy-ins + bracket state SURVIVE a restart (money-critical).
model Tournament {
  id             String   @id
  name           String
  buyInCents     Int
  capacity       Int
  status         String   @default("registering") // registering|running|awaiting_confirmation|finished|cancelled — a DB CHECK constraint guards the set (see migration 20260624010000)
  playerIds      Json     @default("[]")
  bracket        Json     @default("[]")
  prizePoolCents Int      @default(0)
  rakeBps        Int
  winnerId       String?
  // Dual-control (four-eyes) for the champion payout: the final was reported but is
  // awaiting a SECOND, distinct admin's confirmation before money moves. Both null when
  // not pending. Config-gated (off by default → single-admin/solo operation unaffected).
  pendingWinnerId   String?
  reportedByAdminId String?
  // Club-scoped tournament: null = global (public list); non-null = belongs to a club
  // (joinable only by members, creatable only by the founder). FK with ON DELETE SET NULL:
  // if a club is deleted, its tournaments DEGRADE to global (clubId → null) rather than
  // dangling — escrow stays safe (sweepStale uses listAll) and the row stays reachable.
  clubId         String?
  club           Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([status, createdAt])
  @@index([clubId, createdAt]) // serves list (clubId IS NULL) + listByClub, both ORDER BY createdAt
  @@map("tournaments")
}
